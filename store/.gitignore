# .gitignore - Django Project ke liye

# 🔒 Security - Kabhi upload nahi karna
*.key
*.pem
*.crt
*.env
secrets.json

# 🗄️ Database (Optional - agar fresh start chahiye)
db.sqlite3

# 📦 Virtual Environment
env/
venv/
ENV/
.venv/

# 🐍 Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 🎨 IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# 🌐 Django
*.log
local_settings.py
staticfiles/

# 📸 Media Files (Optional - agar bade hain)
media/products/
media/*.jpg
media/*.png

# 📦 Node modules (agar kabhi use karein)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 🗂️ OS Files
.DS_Store
Thumbs.db
ehthumbs.db

# 🔍 Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/